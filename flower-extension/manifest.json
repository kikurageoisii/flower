{
  "manifest_version": 3,
  "name": "Flower Page",
  "version": "1.0",
  "description": "Replace webpage text and images with flowers and animals.",
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}